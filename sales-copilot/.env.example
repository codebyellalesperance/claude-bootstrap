# Sales Copilot -- environment variables
#
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# Every variable below is required unless marked optional.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# One of: development | staging | production
ENVIRONMENT=development

# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Microsoft Graph (Outlook + Excel)
#
# Get these from the Azure portal:
#   1. https://portal.azure.com -> Microsoft Entra ID -> App registrations
#   2. "New registration": single tenant, redirect URI = http://localhost:8000/auth/callback
#   3. Copy the Application (client) ID and Directory (tenant) ID below
#   4. Certificates & secrets -> "New client secret" -> copy the VALUE (not the ID)
#   5. API permissions -> "Add a permission" -> Microsoft Graph -> Delegated:
#        - Mail.ReadWrite
#        - Files.ReadWrite.All
#        - offline_access
#      Then click "Grant admin consent".
# ---------------------------------------------------------------------------

# Directory (tenant) ID from Azure AD app overview.
GRAPH_TENANT_ID=

# Application (client) ID from Azure AD app overview.
GRAPH_CLIENT_ID=

# Client secret VALUE (copy on creation; cannot be retrieved later).
GRAPH_CLIENT_SECRET=

# Redirect URI registered on the app. Must match exactly.
GRAPH_REDIRECT_URI=http://localhost:8000/auth/callback

# Space-delimited delegated scopes. Leave default unless adding new ones.
GRAPH_SCOPES=Mail.ReadWrite Files.ReadWrite.All offline_access

# Refresh token obtained after the one-time interactive sign-in. See
# README.md "First-run sign-in" for the helper command.
GRAPH_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Salesforce Connected App (client credentials flow)
#
# Get these from Salesforce Setup:
#   1. Setup -> App Manager -> "New Connected App"
#   2. Enable OAuth Settings:
#        - Callback URL: http://localhost (unused for client credentials)
#        - Scopes: "Manage user data via APIs (api)" and "Perform requests at any time (refresh_token, offline_access)"
#   3. After save, open "Manage Consumer Details" to copy Consumer Key + Secret.
#   4. Edit Policies -> set "Permitted Users" = "Admin approved users are pre-authorized"
#      and pick an integration user as "Run As" in OAuth Policies.
#   5. Your instance URL is the My Domain URL (Setup -> My Domain).
# ---------------------------------------------------------------------------

# My Domain URL, e.g. https://yourorg.my.salesforce.com (no trailing slash).
SALESFORCE_INSTANCE_URL=

# Connected App Consumer Key.
SALESFORCE_CLIENT_ID=

# Connected App Consumer Secret.
SALESFORCE_CLIENT_SECRET=

# Salesforce REST API version. Bump to match your org's release.
SALESFORCE_API_VERSION=v60.0
